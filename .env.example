# ── LLM providers ────────────────────────────────────────────────────────────
# Primary: Cerebras (~450 tok/s on 70B, free — https://cloud.cerebras.ai)
CEREBRAS_API_KEY=your_cerebras_api_key

# Fallback: Groq (~320 tok/s on 70B, free — https://console.groq.com)
GROQ_API_KEY=your_groq_api_key

# Optional: override model names (defaults shown)
# CEREBRAS_MODEL=llama-3.3-70b
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Video sources ─────────────────────────────────────────────────────────────
# Required for Mode 0 (Stock Footage) only
PEXELS_API_KEY=GenerateFromHere-https://www.pexels.com/api/

# ── Reddit (Mode 1 only) ──────────────────────────────────────────────────────
# Create a "script" app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# ── YouTube upload (optional) ─────────────────────────────────────────────────
# YOUTUBE_CLIENT_SECRETS=client_secrets.json
